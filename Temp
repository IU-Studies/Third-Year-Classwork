To compute FIRST and FOLLOW sets for a given grammar.

productions = []
non_terminals = set()

first_cache = {}
follow_cache = {}


def load_file():
    global productions, non_terminals

    with open("input.txt", "r") as f:
        productions = [line.strip() for line in f if line.strip()]

    for p in productions:
        non_terminals.add(p[0])


def first(symbol):
    if symbol in first_cache:
        return first_cache[symbol]

    result = []

    if symbol not in non_terminals:
        return [symbol]

    for prod in productions:
        if prod[0] == symbol:
            rhs = prod[2:]

            for ch in rhs:

                if ch not in non_terminals:
                    if ch not in result:
                        result.append(ch)
                    break

                else:
                    f = first(ch)

                    for x in f:
                        if x != '#' and x not in result:
                            result.append(x)

                    if '#' not in f:
                        break

    first_cache[symbol] = result
    return result

def follow(symbol):
    if symbol in follow_cache:
        return follow_cache[symbol]

    result = []

    # Start symbol
    if productions[0][0] == symbol:
        result.append('$')

    for prod in productions:
        lhs = prod[0]
        rhs = prod[2:]

        for i in range(len(rhs)):
            if rhs[i] == symbol:

                if i + 1 < len(rhs):

                    next_sym = rhs[i + 1]

                    f = first(next_sym)

                    for x in f:
                        if x != '#' and x not in result:
                            result.append(x)

                    if '#' in f:
                        f2 = follow(lhs)
                        for x in f2:
                            if x not in result:
                                result.append(x)

                else:
                    if lhs != symbol:
                        f2 = follow(lhs)
                        for x in f2:
                            if x not in result:
                                result.append(x)

    follow_cache[symbol] = result
    return result


load_file()

print("Productions:")
for p in productions:
    print(p)

print("\n===== FIRST =====")
for nt in non_terminals:
    first_cache.clear()
    print(f"FIRST({nt}) = {{ {' '.join(first(nt))} }}")

print("\n===== FOLLOW =====")
for nt in non_terminals:
    follow_cache.clear()
    print(f"FOLLOW({nt}) = {{ {' '.join(follow(nt))} }}")


