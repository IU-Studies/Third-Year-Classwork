#include <stdio.h>
#include <string.h>
#include <stdlib.h>

/* ---------- TABLE STRUCTURES ---------- */
struct MOT {
    char mnemonic[10];
    int opcode;
};

struct POT {
    char directive[10];
    char type[3]; // AD or DL
    int code;
};

struct SYMTAB {
    char symbol[10];
    int address;
};

struct LITTAB {
    char literal[10];
    int address;
};

/* ---------- TABLE INITIALIZATION ---------- */
struct MOT mot[] = {
    {"STOP", 0}, {"ADD", 1}, {"SUB", 2}, {"MUL", 3}, {"MOV", 4}
};

struct POT pot[] = {
    {"START", "AD", 1},
    {"END", "AD", 2},
    {"LTORG", "AD", 3},
    {"DS", "DL", 1},
    {"DC", "DL", 2}
};

struct SYMTAB st[20];
struct LITTAB lt[20];

int symCnt = 0, litCnt = 0;
int LC = 0, poolPtr = 0;

/* ---------- UTILITY FUNCTIONS ---------- */
int searchMOT(char op[]) {
    for (int i = 0; i < 5; i++)
        if (strcmp(mot[i].mnemonic, op) == 0)
            return i;
    return -1;
}

int searchPOT(char op[]) {
    for (int i = 0; i < 5; i++)
        if (strcmp(pot[i].directive, op) == 0)
            return i;
    return -1;
}

int addSymbol(char sym[], int addr) {
    for (int i = 0; i < symCnt; i++)
        if (strcmp(st[i].symbol, sym) == 0)
            return i;

    strcpy(st[symCnt].symbol, sym);
    st[symCnt].address = addr;
    return symCnt++;
}

int addLiteral(char lit[]) {
    for (int i = 0; i < litCnt; i++)
        if (strcmp(lt[i].literal, lit) == 0)
            return i;

    strcpy(lt[litCnt].literal, lit);
    lt[litCnt].address = -1;
    return litCnt++;
}

void assignLiterals() {
    for (int i = poolPtr; i < litCnt; i++) {
        lt[i].address = LC;
        LC++;
    }
    poolPtr = litCnt;
}

/* ---------- MAIN ---------- */
int main() {
    char label[10], opcode[10], operand[10];

    printf("Enter Assembly Program (END to stop):\n\n");

    while (1) {
        scanf("%s %s %s", label, opcode, operand);

        /* START */
        if (strcmp(opcode, "START") == 0) {
            LC = atoi(operand);
            printf("(AD,01) (C,%d)\n", LC);
            continue;
        }

        /* END */
        if (strcmp(opcode, "END") == 0) {
            assignLiterals();
            printf("(AD,02)\n");
            break;
        }

        /* LTORG */
        if (strcmp(opcode, "LTORG") == 0) {
            assignLiterals();
            printf("(AD,03)\n");
            continue;
        }

        /* Add label to Symbol Table */
        if (strcmp(label, "-") != 0)
            addSymbol(label, LC);

        /* Declarative Statements */
        if (strcmp(opcode, "DS") == 0) {
            printf("(DL,01) (C,%d)\n", atoi(operand));
            LC += atoi(operand);
            continue;
        }

        if (strcmp(opcode, "DC") == 0) {
            printf("(DL,02) (C,%d)\n", atoi(operand));
            LC++;
            continue;
        }

        /* Imperative Statements */
        int m = searchMOT(opcode);
        if (m != -1) {
            printf("(IS,%02d) ", mot[m].opcode);

            if (operand[0] == '=') {
                int l = addLiteral(operand);
                printf("(L,%d)\n", l);
            } else {
                int s = addSymbol(operand, -1);
                printf("(S,%d)\n", s);
            }

            LC++;
        }
    }

    /* ---------- DISPLAY TABLES ---------- */
    printf("\nSYMBOL TABLE\n");
    printf("Index\tSymbol\tAddress\n");
    for (int i = 0; i < symCnt; i++)
        printf("%d\t%s\t%d\n", i, st[i].symbol, st[i].address);

    printf("\nLITERAL TABLE\n");
    printf("Index\tLiteral\tAddress\n");
    for (int i = 0; i < litCnt; i++)
        printf("%d\t%s\t%d\n", i, lt[i].literal, lt[i].address);

    return 0;
}



