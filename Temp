To design a lexical analyzer in C to identify tokens.

import string

# List of keywords
keywords = [
    "int", "float", "if", "else", "while",
    "return", "for", "char", "double", "void"
]

def is_keyword(word):
    return word in keywords

def main():
    try:
        with open("input.c", "r") as file:
            content = file.read()
    except FileNotFoundError:
        print("Error opening file")
        return

    buffer = ""

    for ch in content:
        # Identifiers or Keywords
        if ch.isalnum():
            buffer += ch
        else:
            if buffer != "":
                if is_keyword(buffer):
                    print(f"{buffer} is Keyword")
                else:
                    print(f"{buffer} is Identifier")
                buffer = ""

            # Operators
            if ch in ['+', '-', '*', '/', '=']:
                print(f"{ch} is Operator")

            # Special Symbols
            if ch in [';', ',', '(', ')', '{', '}']:
                print(f"{ch} is Special Symbol")

    # To handle last word if file doesn't end with space/newline
    if buffer != "":
        if is_keyword(buffer):
            print(f"{buffer} is Keyword")
        else:
            print(f"{buffer} is Identifier")


if __name__ == "__main__":
    main()

