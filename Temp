To simulate an absolute loader for loading object code into memory.
MEMORY_SIZE = 65536
memory = [0] * MEMORY_SIZE

def main():
    start_address = 0
    length = 0
    exec_address = 0
    loaded_addresses = []

    try:
        with open("input.asm", "r") as file:
            records = file.readlines()
    except FileNotFoundError:
        print("Error: input.asm file not found.")
        return

    for record in records:
        record = record.strip()

        if record == "END":
            break

        if record.startswith('H'):
            parts = [p.strip() for p in record.split('^')]
            start_address = int(parts[2], 16)
            length = int(parts[3], 16)

            print(f"Program starting address: {start_address:04X}")
            print(f"Program length: {length:04X}")

        elif record.startswith('T'):
            parts = [p.strip() for p in record.split('^')]
            address = int(parts[1], 16)
            object_code = parts[3]

            for i in range(0, len(object_code), 2):
                byte = object_code[i:i+2]
                memory[address] = int(byte, 16)
                loaded_addresses.append(address)
                address += 1

        elif record.startswith('E'):
            parts = [p.strip() for p in record.split('^')]
            exec_address = int(parts[1], 16)
            print(f"Execution begins at address: {exec_address:04X}")

    # Print only loaded memory
    print("\nLoaded Memory:")
    for addr in loaded_addresses:
        print(f"{addr:04X} : {memory[addr]:02X}")


if __name__ == "__main__":
    main()

