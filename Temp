#include <stdio.h>
#include <string.h>

#define MAX 20
#define LENGTH 100

// Macro Name Table
struct MNT {
    char name[20];
    int mdt_index;
};

struct MNT mnt[10];
char mdt[100][LENGTH];

int mnt_count = 0;
int mdt_count = 0;

int main() {
    char line[LENGTH];
    int insideMacro = 0;

    printf("Enter Assembly Program (Type END to stop):\n");

    while (1) {
        fgets(line, LENGTH, stdin);
        line[strcspn(line, "\n")] = 0; // remove newline

        if (strcmp(line, "END") == 0) {
            printf("END\n");
            break;
        }

        // Start Macro Definition
        if (strcmp(line, "MACRO") == 0) {
            insideMacro = 1;

            // Read Macro Name
            fgets(line, LENGTH, stdin);
            line[strcspn(line, "\n")] = 0;

            strcpy(mnt[mnt_count].name, line);
            mnt[mnt_count].mdt_index = mdt_count;
            mnt_count++;

            continue;
        }

        // Store Macro Body
        if (insideMacro) {
            if (strcmp(line, "MEND") == 0) {
                insideMacro = 0;
            } else {
                strcpy(mdt[mdt_count++], line);
            }
            continue;
        }

        // Check for Macro Call
        int found = 0;
        for (int i = 0; i < mnt_count; i++) {
            if (strcmp(line, mnt[i].name) == 0) {
                printf("\nExpanded Code:\n");

                int index = mnt[i].mdt_index;
                while (index < mdt_count) {
                    printf("%s\n", mdt[index]);
                    index++;
                }

                found = 1;
                break;
            }
        }

        // Normal instruction
        if (!found) {
            printf("%s\n", line);
        }
    }

    return 0;
}

